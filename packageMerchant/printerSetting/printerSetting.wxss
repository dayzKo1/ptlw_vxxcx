.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.status-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.status-badge {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.status-badge.connected {
  background: #e8f5e9;
  color: #4caf50;
}

.status-badge.disconnected {
  background: #ffebee;
  color: #f44336;
}

.status-info {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.info-label {
  color: #999;
  margin-right: 16rpx;
}

.info-value {
  color: #333;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.search-btn {
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  background: #FF6B6B;
  color: #fff;
  border-radius: 32rpx;
  border: none;
}

.search-btn::after {
  border: none;
}

.search-btn[disabled] {
  background: #ccc;
}

.device-list {
  border-top: 1rpx solid #eee;
  padding-top: 16rpx;
}

.device-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.device-info {
  display: flex;
  flex-direction: column;
}

.device-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.device-id {
  font-size: 24rpx;
  color: #999;
}

.device-action {
  padding: 12rpx 32rpx;
  background: #FF6B6B;
  border-radius: 24rpx;
}

.action-text {
  font-size: 26rpx;
  color: #fff;
}

.empty-tip {
  text-align: center;
  padding: 48rpx 0;
  color: #999;
  font-size: 28rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 30rpx;
  color: #333;
}

.action-section {
  padding: 32rpx 0;
}

.test-btn {
  width: 100%;
  height: 88rpx;
  background: #FF6B6B;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
  margin-bottom: 24rpx;
}

.test-btn::after {
  border: none;
}

.test-btn[disabled] {
  background: #ccc;
}

.disconnect-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #f44336;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: 1rpx solid #f44336;
}

.disconnect-btn::after {
  border: none;
}

.help-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.help-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.help-item {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}