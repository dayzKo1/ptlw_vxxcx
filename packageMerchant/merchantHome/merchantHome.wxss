.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  box-sizing: border-box;
}

/* 顶部区域 */
.header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-info {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.header-subtitle {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  gap: 24rpx;
}

.header-link {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  padding: 8rpx 0;
}

/* 打印机状态栏 */
.printer-status-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF3E0;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #FFE0B2;
}

.printer-status-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.printer-status-text {
  font-size: 26rpx;
  color: #E65100;
}

/* 自动接单开关栏 */
.auto-accept-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.auto-accept-info {
  display: flex;
  flex-direction: column;
}

.auto-accept-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.auto-accept-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 主导航 */
.main-tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.main-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.main-tab.active {
  color: #FF6B6B;
  font-weight: bold;
}

.main-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #FF6B6B;
  border-radius: 2rpx;
}

/* 内容区域 */
.content-area {
  flex: 1;
}

/* 子导航 */
.sub-tabs {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  background: #fff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sub-tab {
  display: inline-flex;
  flex-shrink: 0;
  padding: 10rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 24rpx;
  margin-right: 16rpx;
}

.sub-tab:last-child {
  margin-right: 0;
}

.sub-tab.active {
  background: #FF6B6B;
  color: #fff;
}

/* 列表容器 */
.list-container {
  height: calc(100vh - 320rpx);
  padding: 16rpx;
  box-sizing: border-box;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  width: 88rpx;
  height: 88rpx;
  background: #FF6B6B;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255,107,107,0.3);
  z-index: 50;
}

/* 批量操作按钮 */
.batch-actions {
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.batch-btn {
  width: 100%;
  background: linear-gradient(135deg, #2196F3 0%, #42A5F5 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  border: none;
}

.batch-btn[disabled] {
  background: #ccc;
}

/* 日期筛选 */
.date-filter {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.date-picker-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.date-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.date-text {
  font-size: 26rpx;
  color: #333;
}

.date-arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 8rpx;
}

.date-quick-btns {
  display: flex;
  gap: 16rpx;
}

.date-quick-btn {
  font-size: 24rpx;
  color: #666;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.date-quick-btn.active {
  color: #fff;
  background: #FF6B6B;
}

/* 日期分组标题 */
.date-group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #f5f5f5;
  margin: 8rpx 0;
  border-radius: 8rpx;
}

.date-group-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.date-group-count {
  font-size: 22rpx;
  color: #999;
}

/* 视图切换 */
.view-switch {
  display: flex;
  background: #fff;
  padding: 12rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.view-switch-btn {
  font-size: 26rpx;
  color: #666;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.view-switch-btn.active {
  color: #fff;
  background: #FF6B6B;
}

/* 网格视图 - 状态总览 */
.table-grid-view {
  padding: 16rpx;
}

.grid-stats {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.grid-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.grid-stat-item .stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.grid-stat-item.idle .stat-value {
  color: #4CAF50;
}

.grid-stat-item.occupied .stat-value {
  color: #FF6B6B;
}

.grid-stat-item .stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.table-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.table-grid-item {
  width: calc(25% - 12rpx);
  aspect-ratio: 1;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.table-grid-item.idle {
  background: #E8F5E9;
  border-color: #4CAF50;
}

.table-grid-item.occupied {
  background: #FFEBEE;
  border-color: #FF6B6B;
}

.table-grid-item.add-new {
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
}

.grid-table-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.table-grid-item.idle .grid-table-number {
  color: #4CAF50;
}

.table-grid-item.occupied .grid-table-number {
  color: #FF6B6B;
}

.grid-table-status {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.grid-table-time {
  font-size: 18rpx;
  color: #999;
  margin-top: 4rpx;
}

.table-grid-item.add-new .add-icon {
  font-size: 48rpx;
  color: #999;
}

.table-grid-item.add-new .add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.table-list-view {
  flex: 1;
}