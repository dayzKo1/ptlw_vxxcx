<view class="container">
  <view class="login-card">
    <view class="logo-section">
      <view class="logo">🏪</view>
      <text class="app-name">平潭礼物</text>
      <text class="app-desc">扫码点餐，轻松用餐</text>
    </view>

    <!-- 新版登录方式 -->
    <view class="login-section" wx:if="{{!isDev}}">
      <view class="profile-section">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <text class="avatar-tip">点击选择头像</text>
        </button>
        
        <view class="nickname-section">
          <text class="nickname-label">昵称</text>
          <input class="nickname-input" type="nickname" placeholder="请输入昵称" bindinput="onNicknameInput" bindblur="onNicknameBlur" value="{{nickname}}" />
        </view>
      </view>

      <button class="login-btn" bindtap="handleLogin">
        <text class="login-icon">📱</text>
        <text class="login-text">微信登录</text>
      </button>

      <view class="agreement">
        <text class="agreement-text">登录即表示同意</text>
        <text class="agreement-link">《用户协议》</text>
        <text class="agreement-text">和</text>
        <text class="agreement-link">《隐私政策》</text>
      </view>
    </view>

    <!-- 开发模式 -->
    <view class="login-section" wx:if="{{isDev}}">
      <view class="dev-section">
        <view class="dev-role-section">
          <text class="dev-role-title">开发模式 - 选择身份</text>
          <view class="role-options">
            <view class="role-option {{selectedRole === 'customer' ? 'active' : ''}}" bindtap="selectRole" data-role="customer">
              <text class="role-name">客户</text>
            </view>
            <view class="role-option {{selectedRole === 'merchant' ? 'active' : ''}}" bindtap="selectRole" data-role="merchant">
              <text class="role-name">商户</text>
            </view>
          </view>
        </view>
        <button class="dev-login-btn" bindtap="handleDevLogin">
          <text class="dev-login-icon">🔧</text>
          <text class="dev-login-text">开发环境模拟登录</text>
        </button>
      </view>
    </view>

    <view class="dev-toggle">
      <text class="dev-toggle-text">开发模式</text>
      <switch class="dev-switch" checked="{{isDev}}" bindchange="toggleDevMode" />
    </view>

    <view class="tips-section">
      <text class="tips-text">首次登录将自动创建账号</text>
    </view>
  </view>
</view>